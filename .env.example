# AI API 配置
# 选择以下其中一个 AI 服务

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 阿里云通义千问配置 (二选一)
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_MODEL=qwen-turbo

# Kafka 配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_LOGS_TOPIC=logs_raw
KAFKA_ANALYZED_TOPIC=logs_analyzed
KAFKA_CONSUMER_GROUP=log_analysis_group

# ClickHouse 配置
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=log_analysis
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_password_here

# Elasticsearch 配置 (可选，如不使用可留空)
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=logs-*
ES_USER=elastic
ES_PASSWORD=your_password_here

# 日志采集配置
LOG_SOURCES_CONFIG=config/log_sources.yml

# 应用配置
LOG_LEVEL=INFO
LOG_OUTPUT_DIR=logs
REPORT_OUTPUT_DIR=reports
DATA_RETENTION_DAYS=90

# Streamlit 配置
STREAMlit_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# 行为分析配置
# 时间窗口 (小时)
BEHAVIOR_TIME_WINDOW_HOURS=24
# 异常检测阈值 (0-1)
ANOMALY_THRESHOLD=0.7
# 最小样本数 (用于建立用户画像)
MIN_SAMPLES_FOR_PROFILE=10
